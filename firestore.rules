rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Firestore 보안 규칙 (인증 필수)
// - 로그인(Firebase Auth)한 사용자만 모든 문서를 읽고 쓸 수 있다.
// - 계정 생성은 Firebase Console 에서만 하므로 = 내부 임직원만 접근 가능.
// - ⚠️ Firebase Console → Authentication → Sign-in method 에서
//   "익명(Anonymous)" 로그인은 반드시 '사용 안 함' 으로 두어야 한다.
//   (익명 로그인이 켜져 있으면 누구나 인증 토큰을 얻어 우회 가능)
//
// 적용 방법:
//  A) Firebase Console → Firestore Database → 규칙 탭 → 아래 내용 붙여넣기 → '게시'
//  B) 또는 Firebase CLI:  firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
